# Backend API URL
# Used by the frontend to connect to the spell checker API
# Default: http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Feedback form — creates GitHub issues from user submissions
# A GitHub PAT with Issues read/write on the target repo (not NEXT_PUBLIC_ — server-side only)
GITHUB_FEEDBACK_TOKEN=
# Optional: override the target repo (default: stellakunzang/butter-dots-dot-com)
# GITHUB_FEEDBACK_REPO=owner/repo

# Optional: Formspree endpoint to receive email notifications of feedback submissions
# Create a form at https://formspree.io and paste the endpoint here (e.g. https://formspree.io/f/xyzabc)
# FORMSPREE_ENDPOINT=
