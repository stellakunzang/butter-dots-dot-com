# ──────────────────────────────────────────────
# Root .env.example — reference for all services
# ──────────────────────────────────────────────
# Each service reads its own .env file:
#   backend/.env   — backend settings
#   frontend/.env.local  — frontend settings (Next.js convention)
#
# Copy the relevant sections below into those files for local dev.
# In production, set these as environment variables on your hosting provider.

# ── Backend (backend/.env) ────────────────────
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000
# Debug mode (disable in production)
DEBUG=true

# BDRC OCR model directory name under backend/OCRModels/
# Options: Woodblock, Woodblock-Stacks, Modern, Ume_Druma, Ume_Petsuk
OCR_MODEL_NAME=Woodblock

# ── Interactive OCR (local-only; behind-flag in prod) ──
# Required when running: python -m app.ocr_assist.run_job ... --enable-ai
ANTHROPIC_API_KEY=

# Optional — only if using Gemini vision fallback (--vision-provider gemini)
# Also accepts GOOGLE_API_KEY. Requires: pip install 'google-genai>=1.0.0'
GEMINI_API_KEY=

# Optional provider overrides (defaults shown)
# DIAGNOSTICIAN_PROVIDER=anthropic
# VISION_OCR_PROVIDER=anthropic

# See docs/planning/INTERACTIVE_OCR_LOCAL_SMOKE.md for local smoke-test steps.

# ── Frontend (frontend/.env.local) ────────────
# URL where the backend API is running
NEXT_PUBLIC_API_URL=http://localhost:8000
