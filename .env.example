# ──────────────────────────────────────────────
# Root .env.example — reference for all services
# ──────────────────────────────────────────────
# Each service reads its own .env file:
#   backend/.env   — backend settings
#   frontend/.env.local  — frontend settings (Next.js convention)
#
# Copy the relevant sections below into those files for local dev.
# In production, set these as environment variables on your hosting provider.

# ── Backend (backend/.env) ────────────────────
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000
# Debug mode (disable in production)
DEBUG=true

# ── Frontend (frontend/.env.local) ────────────
# URL where the backend API is running
NEXT_PUBLIC_API_URL=http://localhost:8000
