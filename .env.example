# Frontend Environment Variables
# Copy this to frontend/.env.local for local development

# API URL (backend)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend Environment Variables  
# Docker sets these automatically via docker-compose.yml
# Only needed for manual (non-Docker) setup

# Database connection
DATABASE_URL=postgresql://tibetan:dev_password@localhost:5432/tibetan_spellcheck

# App settings
DEBUG=true
PYTHONUNBUFFERED=1

# Production settings (not needed for local development)
# DATABASE_URL=your-production-database-url
# SECRET_KEY=your-secret-key
# ALLOWED_ORIGINS=https://yourdomain.com
